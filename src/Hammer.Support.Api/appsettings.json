{
  "Serilog": {
    "Using": ["Serilog.Sinks.Console"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {TraceId} {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Enrich": ["FromLogContext"]
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=hammer_support;Username=postgres;Password=postgres"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092",
    "LingerMs": 5,
    "BatchSize": 100,
    "ConsumerGroupId": "hammer-support"
  },
  "Onbid": {
    "ServiceKey": "",
    "KamcoBaseUrl": "http://openapi.onbid.co.kr/openapi/services/KamcoPblsalThingInquireSvc",
    "InstitutionBaseUrl": "http://openapi.onbid.co.kr/openapi/services/UtlinsttPblsalThingInquireSvc",
    "CodeBaseUrl": "http://openapi.onbid.co.kr/openapi/services/OnbidCodeInfoInquireSvc",
    "PageSize": 1000,
    "CollectionHour": 9
  },
  "Molit": {
    "ServiceKey": "",
    "BaseUrl": "https://apis.data.go.kr/1613000",
    "PageSize": 100,
    "MonthsToCollect": 3
  }
}
